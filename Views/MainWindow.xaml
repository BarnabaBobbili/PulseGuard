<Window x:Class="PulseGuard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:PulseGuard.ViewModels"
        mc:Ignorable="d"
        Title="PulseGuard — Patient Monitor"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="VitalValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="56"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="VitalLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ChartTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A6B3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#219A4E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#155C30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="12">

        <Border DockPanel.Dock="Top"
                Background="#141414"
                CornerRadius="10"
                Padding="20,12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💓" FontSize="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="PulseGuard"
                                   FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Real-Time Patient Monitor"
                                   FontSize="11" Foreground="#888888"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="ClockTextBlock"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#00FF88" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="DateTextBlock"
                               FontSize="12" Foreground="#888888"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="{Binding StartStopButtonText}"
                        Command="{Binding StartStopCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{Binding AlertBarBrush}"
                CornerRadius="10"
                Padding="16,10"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding AlertMessage}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top">

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="PATIENT" FontSize="11" Foreground="#666666"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding PatientName}"
                                   FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding PatientAge}" FontSize="13" Foreground="#AAAAAA" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding PatientBed}" FontSize="13" Foreground="#AAAAAA" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding PatientId}" FontSize="13" Foreground="#AAAAAA"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="HEART RATE" FontSize="11" Foreground="#666666"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding HeartRateBpm}"
                                   Style="{StaticResource VitalValueStyle}"
                                   Foreground="#FF4444"/>
                        <TextBlock Text="BPM" Style="{StaticResource VitalLabelStyle}"/>
                        <TextBlock Text="Normal: 60–100 BPM"
                                   FontSize="11" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="BLOOD OXYGEN (SpO2)" FontSize="11" Foreground="#666666"
                                   FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SpO2Percentage, StringFormat='{}{0:F1}'}"
                                   Style="{StaticResource VitalValueStyle}"
                                   Foreground="#00BFFF"/>
                        <TextBlock Text="%" Style="{StaticResource VitalLabelStyle}"/>
                        <TextBlock Text="Normal: 94–100%"
                                   FontSize="11" Foreground="#555555"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="ALERT THRESHOLDS" FontSize="11" Foreground="#666666"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Fill="#FF4444"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="HR &gt; 120 BPM" FontSize="12" Foreground="#CCCCCC"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#FF4444"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="SpO2 &lt; 90%" FontSize="12" Foreground="#CCCCCC"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Fill="LimeGreen"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="ECG — Electrocardiogram"
                                       Style="{StaticResource ChartTitleStyle}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding EcgSeries}"
                                            XAxes="{Binding HiddenXAxes}"
                                            YAxes="{Binding EcgYAxes}"
                                            Background="Transparent"
                                            AnimationsSpeed="0:0:0"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"/>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse Width="10" Height="10" Fill="#00BFFF"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="SpO2 — Blood Oxygen Saturation (%)"
                                       Style="{StaticResource ChartTitleStyle}"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding SpO2Series}"
                                            XAxes="{Binding HiddenXAxes}"
                                            YAxes="{Binding SpO2YAxes}"
                                            Background="Transparent"
                                            AnimationsSpeed="0:0:0"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
